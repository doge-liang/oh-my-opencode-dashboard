{
  "name": "oh-my-opencode-dashboard",
  "version": "0.5.0",
  "description": "MCP server for visualizing OpenCode & OhMyOpenCode Agent progress",
  "license": "SUL-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/doge-liang/oh-my-opencode-dashboard"
  },
  "main": "./src/server/start.ts",
  "module": "./src/server/start.ts",
  "bin": {
    "oh-my-opencode-dashboard": "./src/server/mcp/bin.ts",
    "omo-dashboard": "./src/server/mcp/bin.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/cli/dev.ts",
    "dev:api": "bun run --watch src/server/start.ts",
    "dev:ui": "bunx --bun vite --port 5173",
    "build": "bun run build:ui && bun run build:api",
    "build:ui": "vite build",
    "build:api": "bun run src/server/build.ts",
    "prepublishOnly": "bun run build && bun test",
    "start": "bun run src/server/start.ts",
    "mcp": "bun run src/server/mcp/bin.ts",
    "cli:sessions": "bun run src/cli/sessions.ts",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "hono": "^4.4.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.25.73"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "type": "module"
}
